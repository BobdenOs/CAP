{
  "name": "@cap-community/cap",
  "version": "0.0.1",
  "description": "Cloud Application Platform",
  "repository": "https://github.com/BobdenOs/CAP.git",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^4.1.2",
    "@sap-cloud-sdk/resilience": "^4.1.2",
    "@sap/cds": "^9",
    "express": "^4",
    "tar": "^7.5.2",
    "undici": "^7.16.0"
  },
  "bin": {
    "cap-deploy": "srv/app/deploy.sh"
  },
  "devDependencies": {
    "@cap-community/cap": ".",
    "@cap-js/cds-test": "^0.4.0",
    "@cap-js/sqlite": "^2.0.2"
  },
  "scripts": {
    "start": "cds-serve",
    "debug": "node --inspect=0.0.0.0:9229 ./node_modules/.bin/cds-serve",
    "docker": "docker compose watch",
    "test": "cds-test",
    "dns:on": "./srv/dns/on.sh",
    "dns:off": "./srv/dns/off.sh",
    "ssl:root": "./ssl/root.sh",
    "ssl:server": "./ssl/server.sh",
    "ssl:client": "./ssl/client.sh",
    "offline:build": "node ./srv/app/offline.js",
    "browser": "npm run dns:on && chromium https://sap.cap/"
  },
  "workspaces": [
    "capire/*"
  ],
  "cds": {
    "folders": {
      "app": "!!!"
    },
    "server": {
      "index": false
    },
    "log": {
      "format": "plain",
      "user": true,
      "levels": {
        "dns": "error",
        "rest": "info",
        "odata": "info",
        "remote": "error"
      }
    },
    "requires": {
      "db": {
        "impl": "srv/db/index.js"
      },
      "auth": {
        "impl": "srv/sec/auth.js"
      }
    }
  }
}
