  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Docker",
      "command": "npm run docker",
      "request": "launch",
      "type": "node-terminal",
      "autoAttachChildProcesses": false
    },
    {
      "name": "Attach cap",
      "type": "node",
      "request": "attach",
      "port": 9000,
      "address": "localhost",
      "restart": false,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [      ],
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Attach sap.cap",
      "type": "node",
      "request": "attach",
      "port": 9001,
      "address": "localhost",
      "restart": false,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [
      ],
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Attach dev.sap.cap",
      "type": "node",
      "request": "attach",
      "port": 9002,
      "address": "localhost",
      "restart": false,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [
      ],
      "presentation": {
        "hidden": true,
      }
    },
  ],
  "compounds": [
    {
      "name": "Attach",
      "configurations": [
