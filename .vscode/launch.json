  "version": "0.2.0",
  "configurations": [
    {
      "name": "start",
      "request": "launch",
      "type": "node",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "env": {
        "DEBUG": "trace"
      },
      "args": [
        "run",
        "start"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "browser",
      "request": "launch",
      "type": "node",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "args": [
        "run",
        "browser"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}