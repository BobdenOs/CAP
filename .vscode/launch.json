{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Docker",
      "command": "npm run docker",
      "request": "launch",
      "type": "node-terminal",
      "autoAttachChildProcesses": false,
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Attach Node",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [],
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Attach cap",
      "type": "node",
      "request": "attach",
      "port": 9000,
      "address": "localhost",
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [],
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Attach sap.cap",
      "type": "node",
      "request": "attach",
      "port": 9001,
      "address": "localhost",
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/home/node/app",
      "skipFiles": [],
      "presentation": {
        "hidden": true,
      }
    },
    {
      "name": "Launch dev.sap.cap",
      "command": "export HOST=$(ip addr show eth0 | grep -oP '\\d+\\.\\d+\\.\\d+\\.\\d+' | head -n 1) && export HOST6=$(ip addr show eth0 | grep global | grep -oP '[\\w:]*:[\\w:]+' | head -n 1) && (sudo kill -9 $(sudo lsof -i -n -P | grep \"$HOST:443 (LISTEN)\" | awk -v n=2 '{print $n}') || true) && sudo -E $(which node) $(pwd)/node_modules/.bin/cds-serve",
      "request": "launch",
      "type": "node-terminal",
      "env": {
        "PORT": "443",
        "NODE_EXTRA_CA_CERTS": "${workspaceFolder}/ssl/ca/ca.crt",
        "CF_INSTANCE_CERT": "${workspaceFolder}/ssl/servers/dev.sap.cap.crt",
        "CF_INSTANCE_KEY": "${workspaceFolder}/ssl/servers/dev.sap.cap.key",
        "FS_MOUNT": "${workspaceFolder}/storage"
      },
      "skipFiles": [
        "<node_internals>/**/*.js",
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "autoAttachChildProcesses": false,
      "presentation": {
        "hidden": false,
      }
    },
  ],
  "compounds": [
    {
      "name": "Launch",
      "configurations": [
        "Launch Docker",
        "Attach cap",
        "Attach sap.cap",
        "Launch dev.sap.cap"
      ]
    }
  ]
}